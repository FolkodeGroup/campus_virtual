# ==============================================================================
# CONFIGURACIÓN DEL PROYECTO - CAMPUS VIRTUAL
# ==============================================================================
# Copia este archivo a ".env" y ajusta los valores para tu entorno local.
# NO subas el archivo ".env" al repositorio de Git.

# --- SERVIDOR (BACKEND) ---
# Puerto en el que corre el servidor Express. Por defecto: 3000
PORT=3000

# Entorno de ejecución: "development" | "production" | "test"
NODE_ENV=development

# --- BASE DE DATOS (POSTGRESQL) ---
# Credenciales para los contenedores de Docker (docker-compose)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DB_PORT=5432

# URL de conexión para Prisma (usada por el backend)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# En Docker local, el HOST es "db". Si usas DB local sin Docker, usa "localhost".
DATABASE_URL=

# --- FRONTEND (VITE) ---
# Puerto local de desarrollo para Vite. Por defecto: 5173
FRONTEND_PORT=5173

# URL base de la API para el frontend
VITE_API_URL=http://localhost:3000/api

# --- SEGURIDAD ---
# Secreto único para la firma de tokens JWT
JWT_SECRET=

# --- OTROS ---
# Tiempo de expiración de sesión (opcional)
TOKEN_EXPIRES_IN=24h
